{
  "name": "sample-counter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsgo -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "solid-js": "^1.9.12",
    "metano-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@typescript/native-preview": "^7.0.0-dev.20260412.1",
    "vite": "^8.0.4",
    "vite-plugin-solid": "^2.11.12"
  },
  "sideEffects": false,
  "imports": {
    "#/*": {
      "types": "./dist/sample-counter/*.d.ts",
      "import": "./dist/sample-counter/*.js",
      "default": "./src/sample-counter/*.ts"
    },
    "#": {
      "types": "./dist/sample-counter/index.d.ts",
      "import": "./dist/sample-counter/index.js",
      "default": "./src/sample-counter/index.ts"
    }
  }
}
